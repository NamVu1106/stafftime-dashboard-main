{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/pages",
    "src/components",
    "src/hooks",
    "src/contexts",
    "src/locales",
    "src/lib",
    "src/main.tsx",
    "src/App.tsx",
    "src/vite-env.d.ts",
    "src/services/api.ts",
    "src/data/departmentMenu.ts",
    "src/scripts"
  ]
}