# SQL Server (Prisma)
# Tạo database trước trên SQL Server, ví dụ: CREATE DATABASE StaffTime;
# Chuỗi kết nối mẫu:
DATABASE_URL="sqlserver://localhost:1433;database=StaffTime;user=sa;password=YourPassword;encrypt=true;trustServerCertificate=true"

# Upload/MERGE lâu — Tedious mặc định 15s. Backend ép 600000ms + chuỗi ADO (Request Timeout trước Password).
SQL_REQUEST_TIMEOUT_MS=600000

# Hoặc Windows Auth (cần cấu hình thêm trên driver — thường dùng user/password cho đơn giản)

JWT_SECRET="your-secret-key-change-in-production"
PORT=3000
FRONTEND_URL=http://localhost:5173
